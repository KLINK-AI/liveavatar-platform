# ============================================
# LiveAvatar Platform — Coolify Deployment Config
# ============================================
# Setze diese Werte in Coolify unter "Environment Variables"
# ============================================

# --- Application ---
APP_ENV=production
APP_SECRET_KEY=           # openssl rand -hex 32
APP_CORS_ORIGINS=https://liveavatar.deine-domain.de

# --- Database (Supabase PostgreSQL) ---
# Supabase Dashboard: Settings → Database → Connection String → URI
# WICHTIG: Ersetze "postgresql://" mit "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- HeyGen LiveAvatar ---
HEYGEN_API_KEY=           # HeyGen Dashboard → API Settings
LIVEAVATAR_API_BASE=https://api.heygen.com

# --- LiveKit Cloud (Free: 10.000 Min/Monat) ---
# https://cloud.livekit.io → Settings → Keys
LIVEKIT_URL=wss://dein-projekt.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- LLM ---
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o

# --- Embeddings ---
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# --- JWT ---
JWT_SECRET_KEY=           # openssl rand -hex 32

# --- Optional ---
# ANTHROPIC_API_KEY=
